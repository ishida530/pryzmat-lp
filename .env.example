# ============================================================
# SMTP — OVH Shared Hosting (ssl0.ovh.net)
# Skopiuj ten plik do .env.local i uzupełnij wartości.
# ============================================================

# Serwer SMTP
SMTP_HOST=ssl0.ovh.net
SMTP_PORT=465
SMTP_SECURE=true

# Dane logowania (pełny adres e-mail jako login — wymagane przez OVH)
SMTP_USER=biuro@pryzmat.com.pl
SMTP_PASS=

# Nadawca widoczny w e-mailu (opcjonalne — domyślnie = SMTP_USER)
SMTP_FROM=biuro@pryzmat.com.pl

# Odbiorca zgłoszeń (opcjonalne — domyślnie = COMPANY.email z lib/constants.ts)
SMTP_TO=biuro@pryzmat.com.pl

# ============================================================
# ALTERNATYWY OVH
# ============================================================
# OVH MXplan/WebHosting — port SSL:     SMTP_HOST=ssl0.ovh.net  PORT=465  SECURE=true
# OVH MXplan/WebHosting — STARTTLS:     SMTP_HOST=ssl0.ovh.net  PORT=587  SECURE=false
# OVH Email Pro:                         SMTP_HOST=pro1.mail.ovh.net  PORT=587  SECURE=false
